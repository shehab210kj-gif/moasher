{
  "name": "magic-patterns-vite-template",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx vite",
    "build": "npx vite build",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "preview": "npx vite preview",
    "typecheck": "npx tsc --noEmit",
    "quality:artifacts": "python src/ai_model/generate_quality_artifacts.py",
    "quality:python": "python -m py_compile src/ai_model/generate_quality_artifacts.py src/ai_model/muasher_api.py src/ai_model/smoke_test_api.py src/ai_model/train_muasher_model.py",
    "quality:api": "python src/ai_model/smoke_test_api.py",
    "verify": "npm run typecheck && npm run quality:python && npm run quality:artifacts && npm run quality:api && npm run build"
  },
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@supabase/supabase-js": "^2.103.2",
    "framer-motion": "^11.5.4",
    "lucide-react": "0.522.0",
    "mapbox-gl": "^3.23.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-map-gl": "^7.1.7",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@types/node": "^20.11.18",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^5.54.0",
    "@typescript-eslint/parser": "^5.54.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "latest",
    "eslint": "^8.50.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.1",
    "postcss": "latest",
    "tailwindcss": "3.4.17",
    "typescript": "^5.5.4",
    "vite": "^5.2.0"
  }
}
